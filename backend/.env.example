# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection String → URI
# Encode special chars in password: @ → %40, # → %23
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_at_least_64_chars

# ─── Frontend URL (used in verification/reset email links) ─────────────────────
# Set to your Vercel deployment URL after deploying frontend
FRONTEND_URL=https://your-app.vercel.app

# ─── Email (Gmail) ─────────────────────────────────────────────────────────────
# Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password

# ─── AI Coach (Groq) ───────────────────────────────────────────────────────────
# Free API key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key

# ─── Plaid Banking Integration ─────────────────────────────────────────────────
# Sign up at: https://dashboard.plaid.com/signup
# sandbox → testing | development → up to 100 real users | production → unlimited
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret_key
PLAID_ENV=sandbox

# Country codes for Plaid (comma-separated) — controls which banks users can link
# US only: US    |   US + UK: US,GB    |   Europe: US,GB,DE,FR,ES,NL
# Note: India is NOT supported by Plaid — use US sandbox for dev/testing
PLAID_COUNTRY_CODES=US

# Webhook URL — Plaid calls this in real time when transactions arrive
# Dev:  Use ngrok: ngrok http 5000  →  https://xxxx.ngrok.io/api/plaid/webhook
# Prod: https://your-backend.railway.app/api/plaid/webhook
PLAID_WEBHOOK_URL=https://your-backend.railway.app/api/plaid/webhook
