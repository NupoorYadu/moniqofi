# Auto-detect text files and normalise line endings to LF on commit
* text=auto eol=lf

# Force LF for shell/gradle scripts
*.sh text eol=lf
gradlew text eol=lf

# Binary files — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary
*.aab binary
*.keystore binary
*.jks binary
